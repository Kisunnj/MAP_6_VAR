<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/card_background"
    app:cardElevation="2dp"
    app:strokeColor="@color/row_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/iconNote"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:contentDescription="@string/label_photo"
            android:scaleType="centerInside"
            tools:src="@drawable/ic_note_text" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textCol1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textStyle="bold"
                tools:text="Заголовок" />

            <TextView
                android:id="@+id/textCol2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/text_secondary"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                tools:text="Текст заметки" />

            <TextView
                android:id="@+id/textCol3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/md_theme_primary"
                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                tools:text="25.05.2026" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
