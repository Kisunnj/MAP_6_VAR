<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <queries>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
        <intent>
            <action android:name="android.intent.action.GET_CONTENT" />
        </intent>
    </queries>

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.Abiturient">
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".LowGradesActivity"
            android:exported="false"
            android:label="@string/title_low_grades"
            android:parentActivityName=".MainActivity" />
        <activity
            android:name=".SortedApplicantsActivity"
            android:exported="false"
            android:label="@string/title_sorted"
            android:parentActivityName=".MainActivity" />
        <activity
            android:name=".SemiPassingActivity"
            android:exported="false"
            android:label="@string/title_semi_passing"
            android:parentActivityName=".MainActivity" />
        <activity
            android:name=".NotesMainActivity"
            android:exported="false"
            android:label="@string/title_notes_extra"
            android:parentActivityName=".MainActivity" />
        <activity
            android:name=".NoteEditActivity"
            android:exported="false"
            android:parentActivityName=".NotesMainActivity" />
    </application>
</manifest>
